{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all windows",
  "windows": ["main", "settings", "overlay"],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://bollyai.dev/**" },
        { "url": "http://**:*/**" },
        { "url": "https://**:*/**" },
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    },
    "updater:default",
    "process:allow-restart"
  ]
}
